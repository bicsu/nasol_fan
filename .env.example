# Supabase (Expo 클라이언트에 주입되는 public 값)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 자체 백엔드 서버 (mTLS 적용 Node.js 서버)
# - 토스 로그인: GET {BACKEND_URL}/auth/toss
# - 토스 콜백: GET {BACKEND_URL}/auth/toss/callback -> FRONTEND_URL?login=success
# - 연결 끊기: POST {BACKEND_URL}/auth/toss/disconnect
EXPO_PUBLIC_BACKEND_URL=https://api.nasolfans.app

# ============================================================
# Vercel Serverless API (api/) 전용 환경변수
# ============================================================

# 토스 mTLS 인증서 (base64 인코딩)
#  base64 -w0 nasol_fans_public.crt | pbcopy  로 값 생성
TOSS_CERT_BASE64=
TOSS_KEY_BASE64=
TOSS_CA_BASE64=

# 토스 OAuth
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_REDIRECT_URI=
TOSS_AUTH_BASE_URL=https://apps-in-toss-api.toss.im

# 콜백 완료 후 프론트로 redirect 할 URL
FRONTEND_URL=

# Supabase Admin (service_role)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Vercel Cron 인증 (임의 랜덤 시크릿)
CRON_SECRET=
