{
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/auth/toss/disconnect", "destination": "/api/auth/disconnect" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/episode-status",
      "schedule": "* * * * *"
    }
  ]
}
